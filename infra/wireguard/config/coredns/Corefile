# CoreDNS config for the WireGuard internal resolver.
#
# Clients in the VPN use 10.13.13.1 as DNS (set via PEERDNS=auto). Names
# in /config/coredns/hosts (generated by prepare-state.sh from
# LAN_IP/LAN_HOSTNAMES in .env) resolve locally; everything else is
# forwarded upstream.

. {
    loop
    errors
    health

    hosts /config/coredns/hosts {
        fallthrough
    }

    forward . /etc/resolv.conf
}
