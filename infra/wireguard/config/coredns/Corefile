# CoreDNS config for the WireGuard internal resolver.
# Minimal: peers don't carry a `DNS = ...` line in their profile (they
# use their OS's normal resolver), so this forwarder is unused in
# practice. Kept lightweight in case any tooling inside the container
# queries it.

. {
    loop
    errors
    health
    forward . /etc/resolv.conf
}
