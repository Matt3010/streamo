# Copia questo file in `.env` (stesso path) e riempi/adatta i valori.
# Il `.env` reale è gitignored.

# ---- Endpoint pubblico WG ----
# IP pubblico di casa (o DDNS hostname).
WIREGUARD_HOST=
WIREGUARD_PORT=51820

# ---- Peers ----
# Lista comma-separated dei dispositivi. Uno per device fisico per
# revoca granulare. La regen di un peer azzera le sue chiavi.
WIREGUARD_PEERS=

# ---- Routing dei client ----
# Subnet pushate ai client. 192.168.1.0/24 = LAN di casa.
# 10.13.13.0/24 = subnet interna WG (necessaria per il DNS).
# Quote la stringa: contiene la virgola che lo shell sourcing
# interpreterebbe male.
WIREGUARD_ALLOWED_IPS="192.168.1.0/24, 10.13.13.0/24"

# `auto` = i client usano il DNS interno (CoreDNS @ 10.13.13.1) che
# risolve i nomi in coredns/hosts (generato da LAN_IP/LAN_HOSTNAMES).
WIREGUARD_DNS=auto

TZ=Europe/Rome

# Subnet interna WG.
WIREGUARD_SUBNET=10.13.13.0

# Utente Linux che owns la state directory. Se inesistente, fallback su PUID/PGID.
WIREGUARD_OWNER=
WIREGUARD_GROUP=
WIREGUARD_PUID=1000
WIREGUARD_PGID=1000

# ---- DNS interno (CoreDNS) ----
# Mapping host -> IP usato da prepare-state.sh per generare il file
# data/coredns/hosts. Aggiungi altri hostname space-separated dopo il
# primo, tutti puntano a LAN_IP.
LAN_IP=192.168.1.99
LAN_HOSTNAMES=streamo.lan
