# Copia questo file in `.env` (stesso path) e riempi/adatta i valori.
# Il `.env` reale è gitignored.

# ---- Endpoint pubblico WG ----
# IP pubblico di casa (o DDNS hostname).
WIREGUARD_HOST=
WIREGUARD_PORT=51820

# ---- Peers ----
# Lista comma-separated dei dispositivi. Uno per device fisico per
# revoca granulare. La regen di un peer azzera le sue chiavi.
WIREGUARD_PEERS=

# ---- Routing dei client ----
# Subnet/IP pushati ai client. Suggerito /32 sul Pi: solo il traffico
# verso il Pi passa nel tunnel. Pacchetti verso altri device LAN (es.
# Apple TV) restano diretti via WiFi → AirPlay funziona anche con VPN
# attiva sulla WiFi di casa.
WIREGUARD_ALLOWED_IPS=192.168.1.99/32

TZ=Europe/Rome

# Subnet interna WG.
WIREGUARD_SUBNET=10.13.13.0

# Utente Linux che owns la state directory. Se inesistente, fallback su PUID/PGID.
WIREGUARD_OWNER=
WIREGUARD_GROUP=
WIREGUARD_PUID=1000
WIREGUARD_PGID=1000
