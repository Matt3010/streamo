# Caddy reverse proxy for streamo over HTTPS.
#
# Cert/key are generated by the `certgen` compose service (mkcert) and stored
# in /certs. The cert is signed by a local CA whose root cert must be
# installed on each device that needs to trust this origin (phone, laptop).
#
# auto_https off → Caddy must not try Let's Encrypt; the cert is provided.

{
	auto_https off
	admin off
	# Clients hitting https://IP send no SNI; Caddy needs a default name
	# to pick the right cert. Any value in CERT_SAN works.
	default_sni {$CADDY_DEFAULT_SNI:192.168.1.99}
}

# Addresses accepted on :443. Driven by .env so adding a new IP/host
# requires only editing CADDY_HOSTS (and CERT_SAN to cover the cert).
{$CADDY_HOSTS:https://192.168.1.99, https://192.168.1.36} {
	tls /certs/streamo.pem /certs/streamo-key.pem

	# warp shares its network namespace with streamo (nginx on :80) and
	# backend (node on :3000). nginx already handles /api/* routing, so
	# we just forward the lot to warp:80.
	reverse_proxy warp:80 {
		# Preserve the client-facing Host so the backend sees the
		# hostname/origin the browser used. Matters for the PWA's
		# service worker scope and cookie domain.
		header_up Host {host}
	}
}
