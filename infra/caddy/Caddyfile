# HTTPS terminator for streamo. Cert obtained from Let's Encrypt via the
# Cloudflare DNS-01 challenge (no port 80 needed). The DNS A record for
# this hostname points to the Pi's private LAN IP (192.168.1.99) — public
# resolvers return it but only LAN-connected devices can actually reach
# the server. This keeps the Pi off the public internet while letting
# devices like Apple TV (which has the Let's Encrypt root in its trust
# store) accept the cert natively, so AirPlay-on-LAN works without
# installing a custom CA on every device.

{
	email {$LE_EMAIL}
	# Default ACME directory is Let's Encrypt prod. No `acme_ca` override.
}

{$CADDY_HOSTS} {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}

	reverse_proxy warp:80 {
		# Preserve the client-facing Host so the backend sees the
		# hostname/origin the browser used. Matters for the PWA's
		# service worker scope and cookie domain.
		header_up Host {host}
	}
}
