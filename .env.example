# Copia questo file in `.env` (allo stesso path) e riempi i placeholder.
# Il `.env` reale è gitignored: lì stanno secrets e config locale.
# Vedi NEW.md per la procedura completa di setup da zero.

# ---- Secrets obbligatori ----
# TMDB API key (https://www.themoviedb.org/settings/api).
TMDB_API_KEY=
# Email dell'utente admin (ricava is_admin nel backend).
SUPER_ADMIN_EMAIL=

# ---- Network bind ----
# Bind warp HTTP su loopback. L'accesso esterno passa per Caddy su :443.
APP_HOST_BIND=127.0.0.1
APP_PORT=7549

# ---- Ownership dei file generati dai container ----
# `id -u` e `id -g` per trovare i tuoi UID/GID.
# I cert containers chownano i file generati a questo UID:GID per
# evitare ownership root e mode world-readable.
APP_OWNER_UID=1000
APP_OWNER_GID=1000

# ---- Worker pool del backend ----
WORKER_CONCURRENCY=4
WORKER_REPLICAS=3

# ---- TMDB rate limiting ----
TMDB_JOB_RATE_LIMIT_MAX=6
TMDB_JOB_RATE_LIMIT_DURATION_MS=1000
TMDB_REFRESH_INTERVAL_SECONDS=1800

# ---- DB migrations ----
AUTO_MIGRATE=true

# ---- Postgres credentials ----
# Modificarli SOLO al primo avvio (data/pg viene inizializzato con questi).
POSTGRES_USER=streamo
POSTGRES_PASSWORD=streamo
POSTGRES_DB=streamo

# ---- Resume reminder ----
RESUME_REMINDER_INTERVAL_SECONDS=86400

# ---- Firebase Cloud Messaging (push notifications) ----
# Lascia vuoti per disabilitare le push (in-app inbox via WebSocket
# continua a funzionare). FCM_SERVICE_ACCOUNT_JSON è il base64 del JSON
# del service account scaricato dalla Firebase Console.
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=

# ---- TLS cert (mkcert + cert-renew daemon) ----
# Aggiungi nomi a CERT_SAN se vuoi raggiungere streamo con altri hostname.
# Quote la stringa quando contiene spazi (lo shell sourcing fallisce
# altrimenti con scripts/up.sh).
CERT_SAN="streamo.lan localhost 127.0.0.1"
CERT_DAYS_THRESHOLD=60
CERT_CHECK_INTERVAL_SEC=86400
CERT_CADDY_CONTAINER=streamingimmunity-caddy-1

# ---- Caddy (reverse proxy + HTTPS terminator) ----
# Solo hostname HTTPS-accettati. Ciò che aggiungi qui deve essere anche
# in CERT_SAN e in infra/wireguard/.env LAN_HOSTNAMES per essere risolto.
CADDY_HOSTS=https://streamo.lan
CADDY_DEFAULT_SNI=streamo.lan
