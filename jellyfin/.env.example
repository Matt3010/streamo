# Copy to .env. No host IP needed anywhere — see note below.

# Ports on the host (unconventional defaults — 7000 is taken by AirPlay
# Receiver on macOS, 8096 may clash with other Jellyfin instances).
JELLYFIN_PORT=18096
ADDON_PORT=17871

# How JELLYFIN reaches the addon — internal docker hostname, never an IP.
# Jellyfin always transcodes this content, so PLAYERS only ever talk to
# Jellyfin (at whatever address they connect with) and never hit the addon
# directly. That means: no LAN IP to hardcode, works on WiFi / hotspot / any
# network without changes.
ADDON_PUBLIC_URL=http://addon:7000

# Leave empty: Jellyfin announces itself using the request host, so clients
# reach it at whatever address they used to connect.
JELLYFIN_PUBLIC_URL=

# Provider catalog locale.
CATALOG_LOCALE=it

# TMDB key — only to translate the imdb/tmdb ids Gelato sends into an SC
# search. Defaults to the key bundled in the iOS app.
TMDB_API_KEY=42b62dc72918b626d8ea3e33c35e16a6
TMDB_LANGUAGE=it-IT
