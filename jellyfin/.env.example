# Copy to .env and fill in.

# Ports on the host (unconventional defaults — 7000 is taken by AirPlay
# Receiver on macOS, 8096 may clash with other Jellyfin instances).
JELLYFIN_PORT=18096
ADDON_PORT=17871

# How PLAYERS (TV, phone, browser) reach the addon's HLS proxy.
# Use the machine's LAN IP, e.g. http://192.168.1.50:17871
ADDON_PUBLIC_URL=http://192.168.1.50:17871

# Jellyfin public URL announced to clients.
JELLYFIN_PUBLIC_URL=http://192.168.1.50:18096

# Provider catalog locale.
CATALOG_LOCALE=it
